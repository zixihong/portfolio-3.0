---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('writing')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
---

<Layout title={`${post.data.title} — bh`}>
  <main class="flex items-center justify-center min-h-screen p-4 sm:p-8">
    <div class="max-w-2xl font-mono text-xs sm:text-sm text-white uppercase space-y-4 sm:space-y-6">
      <div class="space-y-2">
        <div class="text-white/60 text-xs">{post.data.date}</div>
        <div class="text-lg sm:text-xl font-bold">{post.data.title}</div>
      </div>
      <div class="prose prose-invert prose-sm font-mono normal-case">
        <Content />
      </div>
      <div class="pt-4">
        <a href="/writing" class="text-white/60 hover:text-white text-xs underline">← back</a>
      </div>
    </div>
  </main>
</Layout>
