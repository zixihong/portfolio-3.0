---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('writing')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
---

<Layout title="writing">
  <main class="flex items-center justify-center min-h-screen p-4 sm:p-8">
    <div class="max-w-2xl font-mono text-xs sm:text-sm text-white uppercase space-y-4 sm:space-y-8">
      <div class="relative border border-white/60 px-4 py-2 inline-block">
        <span class="absolute -top-[0.7em] -left-[0.5em] bg-black px-[3px] leading-none text-sm text-white/60">┌</span>
        <span class="absolute -top-[0.7em] -right-[0.5em] bg-black px-[3px] leading-none text-sm text-white/60">┐</span>
        <span class="absolute -bottom-[0.7em] -left-[0.5em] bg-black px-[3px] leading-none text-sm text-white/60">└</span>
        <span class="absolute -bottom-[0.7em] -right-[0.5em] bg-black px-[3px] leading-none text-sm text-white/60">┘</span>
        <span class="text-lg sm:text-xl font-bold">Writing</span>
      </div>
      <div class="relative border border-white/30 px-4 py-2 text-white/60 text-xs block w-fit">
        <span class="absolute -top-[0.7em] -left-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">┌</span>
        <span class="absolute -top-[0.7em] -right-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">┐</span>
        <span class="absolute -bottom-[0.7em] -left-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">└</span>
        <span class="absolute -bottom-[0.7em] -right-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">┘</span>
        a collection of writings on things i find interesting.
      </div>

      <div class="space-y-4 sm:space-y-8">
        {posts.map((post) => (
          <div class="relative border border-white/30 px-3 py-3 sm:px-5 sm:py-4 space-y-2">
            <span class="absolute -top-[0.7em] -left-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">┌</span>
            <span class="absolute -top-[0.7em] -right-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">┐</span>
            <span class="absolute -bottom-[0.7em] -left-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">└</span>
            <span class="absolute -bottom-[0.7em] -right-[0.5em] bg-black px-[3px] leading-none text-sm text-white/40">┘</span>
            <div class="text-white/60 text-xs">{post.data.date}</div>
            <a href={`/writing/${post.id}`} class="underline hover:text-white/70 block font-bold">{post.data.title}</a>
            {post.data.description && <div class="text-white/70 text-xs">{post.data.description}</div>}
          </div>
        ))}
      </div>

      <div class="pt-4">
        <a href="/" class="text-white/60 hover:text-white text-xs underline">← back</a>
      </div>
    </div>
  </main>
</Layout>
